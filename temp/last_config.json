{
    "gateway_ip": "192.168.0.1",
    "default_device_count": 5,
    "scan_interval": 2,
    "interface": "en0",
    "stresser": {
        "target_ip": "192.168.0.167",
        "threads": 10,
        "packet_type": "UDP"
    },
    "simulator": {
        "device_count": 5,
        "prefix": "IoT_Dev_"
    },
    "ids": {
        "interface": "en0",
        "config_path": "temp/last_ids_settings.yaml",
        "rules": {
            "detection_settings": {
                "scan_threshold_packets": 100,
                "time_window": 10
            },
            "device_profiles": {
                "IPCamera": {
                    "allowed_protocols": [
                        "UDP",
                        "RTP"
                    ],
                    "max_kbps": 5000
                },
                "LightBulb": {
                    "allowed_protocols": [
                        "TCP",
                        "MQTT"
                    ],
                    "max_kbps": 50
                },
                "Unknown": {
                    "allowed_protocols": [
                        "TCP",
                        "UDP",
                        "ICMP"
                    ],
                    "max_kbps": 100
                }
            },
            "system": {
                "interface": null,
                "log_path": "logs/guardian.log",
                "max_cpu_percent": 80
            },
            "threat_signatures": {
                "DDOS_ATTACK": {
                    "description": "\ud83d\udd25 Critical: Potential Outbound DDoS Attack",
                    "min_kbps": 10000
                },
                "PORT_SCAN": {
                    "description": "\ud83d\udea8 Potential Port Scanning detected (High frequency)",
                    "max_time_gap": 1.0,
                    "min_packet_count": 100,
                    "min_ports": 50
                }
            }
        }
    }
}